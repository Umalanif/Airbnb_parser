DATABASE_URL="file:./dev.db"

# Telegram Bot API credentials
# Get token from @BotFather and chat ID from @userinfobot
TELEGRAM_BOT_TOKEN="your_bot_token_here"
TELEGRAM_CHAT_ID="your_chat_id_here"

# API key for protecting write endpoints
API_KEY="your_secure_api_key_here"

# Optional: Check-in and check-out dates for Airbnb searches
# If not set, defaults to today + 7 days and today + 12 days respectively
# CHECK_IN="2026-04-15"
# CHECK_OUT="2026-04-20"

# Optional: Airbnb session data for automatic seeding
# Run `npx prisma db seed` after setting these to initialize the session
# AIRBNB_COOKIE="your_session_cookie"
# AIRBNB_API_KEY="your_x_airbnb_api_key"
# AIRBNB_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"

PORT=3001
